        "CMAKE_CONFIGURATION_TYPES": "Debug"
      }
    },
    {
      "name": "win32-release",
      "displayName": "Win32 Release",
      "inherits": "vs2022-base",
      "architecture": "Win32",
      "binaryDir": "${sourceDir}/build/win32-release",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Release"
      }
    }
  ],
  "buildPresets": [
