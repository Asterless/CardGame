        "CMAKE_CONFIGURATION_TYPES": "Release"
      }
    },
    {
      "name": "win32-debug",
      "displayName": "Win32 Debug",
      "inherits": "vs2022-base",
      "architecture": "Win32",
      "binaryDir": "${sourceDir}/build/win32-debug",
