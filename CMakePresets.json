        "/p:UseMultiToolTask=false",
        "/p:MultiProcessorCompilation=false",
        "/p:CL_MPCount=1"
      ]
    },
    {
      "name": "win32-debug",
      "displayName": "Build Win32 Debug",
      "configurePreset": "win32-debug",
      "configuration": "Debug",
      "nativeToolOptions": [
        "/m:1",
        "/p:UseMultiToolTask=false",
        "/p:MultiProcessorCompilation=false",
        "/p:CL_MPCount=1"
      ]
    },
    {
      "name": "win32-release",
      "displayName": "Build Win32 Release",
      "configurePreset": "win32-release",
